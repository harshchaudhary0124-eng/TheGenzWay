# ─────────────────────────────────────────────────────────────────────────────
# TheGenzWay backend — environment template (PostgreSQL / Neon only)
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL / Neon — required) ───────────────────────────────────
# Copy the pooled connection string from the Neon dashboard. Keep `sslmode=require`.
# The driver is psycopg2 (already in requirements.txt). The app is PostgreSQL-only
# and refuses to start with any non-PostgreSQL URL.
DATABASE_URL=postgresql://<user>:<password>@<endpoint>-pooler.neon.tech/<db>?sslmode=require

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# In production the app REFUSES to start while SECRET_KEY is empty or "change-me".
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Runtime ───────────────────────────────────────────────────────────────────
# "development" keeps localhost CORS + interactive /docs on.
# "production" enforces a real SECRET_KEY, disables /docs, and enables HSTS.
ENVIRONMENT=development

# Comma-separated list of browser origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Cloudinary (media storage — required in production) ───────────────────────
# All uploaded media (profile images, forum attachments, project assets) is
# stored in Cloudinary, never on the server filesystem. Find these three values
# on your Cloudinary dashboard (Settings → API Keys). They stay on the server
# only — uploads are signed server-side and these are NEVER sent to the browser.
# In production the app REFUSES to start unless all three are set.
# NOTE: never put real secrets in this committed example — fill them in .env only.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Observability / monitoring ────────────────────────────────────────────────
# Reported by GET /health and used as the Sentry release tag. Bump per release.
APP_VERSION=1.0.0

# Root log level: DEBUG | INFO | WARNING | ERROR. In production logs are emitted
# as structured JSON (one object per line) for log drains (Better Stack, etc.).
LOG_LEVEL=INFO

# Sentry error monitoring. Leave blank to disable. Sentry is initialised ONLY
# when ENVIRONMENT=production AND SENTRY_DSN is set. A DSN is not a secret, but
# keep it in .env, not in source.
SENTRY_DSN=
# Fraction of transactions sampled for performance tracing (0.0 disables tracing).
SENTRY_TRACES_SAMPLE_RATE=0.0

# ── Database keep-warm (production cold-start prevention) ─────────────────────
# Seconds between background `SELECT 1` pings that stop Neon's compute from
# auto-suspending (an idle suspend causes a multi-second cold start for the next
# visitor). 0 = disabled (default). Enable ONLY on a Neon plan with enough
# compute hours — always-on consumes compute continuously. Typical value: 240.
DB_KEEPALIVE_SECONDS=0