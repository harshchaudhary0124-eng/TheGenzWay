# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite — zero config, tables auto-created on first run):
DATABASE_URL=sqlite:///./genzway.db

# Production (PostgreSQL — after setting this, run: cd backend && alembic upgrade head):
# DATABASE_URL=postgresql://user:password@localhost:5432/genzway

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
