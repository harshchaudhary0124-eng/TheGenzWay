# ─────────────────────────────────────────────────────────────────────────────
# TheGenzWay frontend — environment template (Next.js)
# Copy to `.env.local` for local dev, or set these in the Vercel dashboard for
# production. Anything prefixed NEXT_PUBLIC_ is exposed to the browser — never put
# a real secret behind a NEXT_PUBLIC_ name. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ───────────────────────────────────────────────────────────
# Base URL of the FastAPI backend. No trailing slash. The WebSocket origin is
# derived from this automatically (http→ws / https→wss).
# Local:      http://127.0.0.1:8000
# Production:  https://api.your-domain.com  (your Railway backend URL)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Public URL of this frontend. Used for canonical/OG metadata.
# Local:      http://localhost:3000
# Production:  https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Runtime flag ──────────────────────────────────────────────────────────────
# Set to "production" in the Vercel production environment. Sentry (below) is
# only enabled when this equals "production".
NEXT_PUBLIC_ENVIRONMENT=development

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Vercel Analytics needs no key — it activates automatically on Vercel.
# PostHog: leave the key blank to disable product-event tracking entirely.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Error monitoring (optional) ───────────────────────────────────────────────
# Sentry DSN for the browser/SSR. A DSN is not a secret. Leave blank to disable.
# Only used when NEXT_PUBLIC_ENVIRONMENT=production.
NEXT_PUBLIC_SENTRY_DSN=
